// TradeNova — Phase 1 MVP data model
// Trade Route Engine, RFQ Marketplace (blind bidding + escrow), Logistics estimation,
// PO-backed Trade Finance, and TradeNova Score (TNS).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth (NextAuth) ----------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Core domain ----------

enum Role {
  EXPORTER
  IMPORTER
  ADMIN
}

enum KycStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum TradeZone {
  USA
  EU
  INDIA
  CHINA
  UAE
}

enum RfqStatus {
  OPEN
  AWARDED
  CANCELLED
  FULFILLED
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum EscrowStatus {
  PENDING
  FUNDED
  PARTIALLY_RELEASED
  RELEASED
  DISPUTED
  REFUNDED
}

enum MilestoneStatus {
  PENDING
  COMPLETE
}

enum FreightMode {
  SEA
  AIR
  ROAD
}

enum TransportStage {
  PICKUP
  PORT_TRANSIT
  INTERNATIONAL_FREIGHT
  CUSTOMS_CLEARANCE
  DELIVERY
  COMPLETE
}

enum LoanStatus {
  REQUESTED
  UNDER_REVIEW
  APPROVED
  FUNDED
  REPAID
  DEFAULTED
  REJECTED
}

enum DocumentType {
  COMMERCIAL_INVOICE
  PACKING_LIST
  CERTIFICATE_OF_ORIGIN
  BILL_OF_LADING
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String
  role          Role
  companyName   String?
  country       String?
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  kycStatus       KycStatus @default(UNVERIFIED)
  kycSubmittedAt  DateTime?
  kycVerifiedAt   DateTime?

  tnsScore Int @default(0)

  accounts Account[]
  sessions Session[]

  rfqsPosted     Rfq[]         @relation("ImporterRfqs")
  bids           Bid[]
  documents      Document[]
  tnsScoreLogs   TnsScoreLog[]
  loans          TradeLoan[]
  exporterShipments Shipment[] @relation("ExporterShipments")
  importerShipments Shipment[] @relation("ImporterShipments")
  logisticsRoutes  LogisticsRoute[]
}

// ---------- Pillar A: Trade Route Engine / Compliance Intelligence ----------

model Country {
  code String    @id // ISO 3166-1 alpha-2
  name String
  zone TradeZone
}

model HsCode {
  code        String @id
  description String
  category    String

  tariffRules TariffRule[]
}

model TariffRule {
  id                  String @id @default(cuid())
  hsCode              String
  originCountry       String
  destinationCountry  String
  tariffPercent       Float
  additionalFeePercent Float @default(0)
  notes               String?

  hsCodeRef HsCode @relation(fields: [hsCode], references: [code])

  @@unique([hsCode, originCountry, destinationCountry])
}

model ComplianceDocument {
  id                 String  @id @default(cuid())
  destinationCountry String
  hsCode             String?
  name               String
  description        String
  required           Boolean @default(true)
}

// ---------- Pillar B: RFQ Marketplace (blind bidding + escrow) ----------

model Rfq {
  id                 String    @id @default(cuid())
  importerId         String
  product            String
  hsCode             String
  originCountry      String
  destinationCountry String
  volume             Float
  unit               String
  targetPricePerUnit Float
  currency           String    @default("USD")
  deadline           DateTime
  status             RfqStatus @default(OPEN)
  awardedBidId       String?   @unique
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  importer User   @relation("ImporterRfqs", fields: [importerId], references: [id])
  bids     Bid[]
  escrow   Escrow?
  shipment Shipment?
  documents Document[]
}

model Bid {
  id               String    @id @default(cuid())
  rfqId            String
  exporterId       String
  pricePerUnit     Float
  message          String?
  aiSuggestedPrice Float?
  status           BidStatus @default(PENDING)
  createdAt        DateTime  @default(now())

  rfq      Rfq  @relation(fields: [rfqId], references: [id])
  exporter User @relation(fields: [exporterId], references: [id])

  @@unique([rfqId, exporterId])
}

model Escrow {
  id         String       @id @default(cuid())
  rfqId      String       @unique
  amount     Float
  currency   String       @default("USD")
  status     EscrowStatus @default(PENDING)
  fundedAt   DateTime?
  releasedAt DateTime?
  createdAt  DateTime     @default(now())

  rfq        Rfq                @relation(fields: [rfqId], references: [id])
  milestones EscrowMilestone[]
}

model EscrowMilestone {
  id          String          @id @default(cuid())
  escrowId    String
  name        String
  sequence    Int
  status      MilestoneStatus @default(PENDING)
  completedAt DateTime?

  escrow Escrow @relation(fields: [escrowId], references: [id])

  @@unique([escrowId, sequence])
}

// ---------- Pillar C: Logistics ----------

model Shipment {
  id                     String         @id @default(cuid())
  rfqId                  String         @unique
  exporterId             String
  importerId             String
  mode                   FreightMode
  transportStage         TransportStage @default(PICKUP)
  status                 String         @default("IN_PROGRESS")
  trackingNumber         String?
  originLocation         String
  destinationLocation    String
  estimatedCost          Float
  actualCost             Float?
  customsClearedAt       DateTime?
  deliveredAt            DateTime?
  tnsScoreAtTimeOfDeal   Int
  aiRouteRecommendation  String?
  createdAt              DateTime       @default(now())

  rfq      Rfq  @relation(fields: [rfqId], references: [id])
  exporter User @relation("ExporterShipments", fields: [exporterId], references: [id])
  importer User @relation("ImporterShipments", fields: [importerId], references: [id])
}

model LogisticsRoute {
  id                  String    @id @default(cuid())
  userId              String
  tradeId             String
  originLocation       String
  destinationLocation  String
  mode                FreightMode
  estimatedCost       Float
  actualCost          Float?
  carrierId           String?
  status              String    @default("PLANNED")
  customsClearedAt    DateTime?
  deliveredAt         DateTime?
  createdAt           DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ---------- Pillar D: Trade Finance ----------

model TradeLoan {
  id                  String     @id @default(cuid())
  exporterId          String
  rfqId               String?
  requestedAmount     Float
  approvedAmount      Float?
  interestRatePercent Float?
  riskBand            String?
  status              LoanStatus @default(REQUESTED)
  requestedAt         DateTime   @default(now())
  fundedAt            DateTime?
  repaidAt            DateTime?

  exporter User @relation(fields: [exporterId], references: [id])
}

// ---------- TradeNova Score (TNS) ----------

model TnsScoreLog {
  id                     String   @id @default(cuid())
  userId                 String
  totalScore             Int
  kycPoints              Int
  onTimeDeliveryPoints   Int
  escrowSpeedPoints      Int
  disputePoints          Int
  loanRepaymentPoints    Int
  calculatedAt           DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ---------- Documents (DocAI stub) ----------

model Document {
  id        String       @id @default(cuid())
  userId    String
  rfqId     String?
  type      DocumentType
  title     String
  content   String       @db.Text
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id])
  rfq  Rfq?  @relation(fields: [rfqId], references: [id])
}
