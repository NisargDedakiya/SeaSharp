DATABASE_URL="postgres://postgres:password@localhost:5432/seasharp"
APP_DATABASE_URL="postgres://app_user:password@localhost:5432/seasharp"
AUTH_JWT_SECRET="replace-with-a-long-random-string-at-least-32-characters"
# Real Supabase project config (src/core/identity/adapter.ts). Leave all
# three blank to use the local bcrypt+JWT identity adapter fallback (no
# live Supabase project needed for dev/test). Set all three to point at a
# real Supabase project — see docs/03-technical-architecture.md.
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
APP_URL="http://localhost:3000"
NODE_ENV="development"
LOG_LEVEL="info"
SENTRY_DSN=""
